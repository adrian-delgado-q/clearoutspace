# ── Redirect www → apex ──────────────────────────────────────────────────────────────────────────────
www.clearoutspaces.ca {
	redir https://clearoutspaces.ca{uri} permanent
}

# ── Main site (Next.js) ──────────────────────────────────────────────────────────────────────────────
clearoutspaces.ca {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Frame-Options           "SAMEORIGIN"
		X-Content-Type-Options    "nosniff"
		Referrer-Policy           "strict-origin"
		Permissions-Policy        "camera=(), microphone=(), geolocation=()"
                # Blocks framing from any origin, restricts object embeds, and
                # prevents base-tag hijacking. script-src includes 'unsafe-inline'
                # because Next.js injects inline hydration scripts; a nonce-based
                # CSP would remove that need but requires server-side plumbing.
                Content-Security-Policy   "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' fonts.googleapis.com; font-src 'self' fonts.gstatic.com; img-src 'self' data: blob: *; connect-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self';"

	# Long-cache for images/fonts
	@assets {
		path_regexp \.(ico|png|jpg|jpeg|gif|webp|svg|woff2|woff|ttf)$
	}
	header @assets Cache-Control "public, max-age=604800"

	reverse_proxy app:3000
}

# ── PocketBase admin (cms.clearoutspaces.ca) ───────────────────────────────────────────────
cms.clearoutspaces.ca {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options    "nosniff"
		Referrer-Policy           "strict-origin"
		-Server
	}

	# Basic auth – restrict only the PocketBase admin UI (/_/).
	# The /api/* paths must remain open so the browser can load files/images.
	# Generate hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'yourpassword'
	@admin path /_/*
	basicauth @admin {
		admin {env.CMS_BASIC_AUTH_HASH}
	}

	# Raise body limit for file uploads
	request_body {
		max_size 50MB
	}

	# WebSocket support for PocketBase realtime / admin UI
	reverse_proxy pocketbase:8090 {
		header_up Host {host}
	}
}
